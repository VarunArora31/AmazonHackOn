# CampusFlow Backend Environment Variables
# Required: Get your API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_actual_key_here

# Optional: Override the default model (llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Server port (defaults to 5000)
# PORT=5000
